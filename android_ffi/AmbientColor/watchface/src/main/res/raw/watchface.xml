<WatchFace height="450" width="450">
    <Metadata key="CLOCK_TYPE" value="DIGITAL" />
    <Scene>
        <Group name="time" width="450" height="450" x="0" y="165">
            <PartText x="0" y="0" width="450" height="24">
                <Text>
                    <Font
                        color="#ffffc91d"
                        family="SYNC_TO_DEVICE"
                        size="24"
                        weight="SEMI_BOLD"
                        letterSpacing="0.1">
                        <Upper>
                            <Template>%s %02d %s
                                <Parameter expression="[DAY_OF_WEEK_S]" />
                                <Parameter expression="[DAY]" />
                                <Parameter expression="[MONTH_S]" />
                            </Template>
                        </Upper>
                    </Font>
                </Text>
                <Variant mode="AMBIENT" target="alpha" value="0" />
            </PartText>
            <DigitalClock height="80" width="450" x="0" y="32">
                <TimeText format="hh:mm" height="80" width="450" x="0" y="0">
                    <Variant mode="AMBIENT" target="alpha" value="0" />
                    <Font color="#ffffc91d" family="SYNC_TO_DEVICE" size="80" />
                </TimeText>
                <TimeText alpha="0" format="hh:mm" height="96" width="450" x="0" y="0">
                    <Variant mode="AMBIENT" target="alpha" value="255" />
                    <Font color="#ffffffff" family="SYNC_TO_DEVICE" size="96" weight="THIN" />
                </TimeText>
            </DigitalClock>
        </Group>
        <!-- Bottom -->
        <PartDraw x="193" y="369" width="64" height="64">
            <Ellipse x="0" y="0" width="64" height="64">
                <Fill color="#ffffffff" />
            </Ellipse>
        </PartDraw>
        <!-- Bottom-right -->
        <ComplicationSlot x="345" y="281" width="64" height="64" slotId="2" supportedTypes="SHORT_TEXT SMALL_IMAGE ICON EMPTY">
            <BoundingOval x="0" y="0" width="64" height="64" />
            <DefaultProviderPolicy
                defaultSystemProvider="HEART_RATE"
                defaultSystemProviderType="SHORT_TEXT" />
            <Complication type="SHORT_TEXT">
                <PartDraw x="0" y="0" width="64" height="64">
                    <Arc centerX="32" centerY="32" width="64" height="64" startAngle="195" endAngle="165">
                        <Stroke color="#ffffffff" thickness="8" />
                    </Arc>
                </PartDraw>
                <PartImage x="22" y="44" width="20" height="20">
                    <Image resource="[COMPLICATION.SMALL_IMAGE]" />
                </PartImage>
                <PartImage x="22" y="44" width="20" height="20">
                    <Image resource="[COMPLICATION.ICON]" />
                </PartImage>
                <PartText x="0" y="0" width="64" height="64">
                    <Text>
                        <Font family="SYNC_TO_DEVICE" size="16" color="#ffffffff" weight="BOLD" letterSpacing="0.1">
                            <Template>
                                <![CDATA[%s]]>
                                <Parameter expression="[COMPLICATION.TEXT]" />
                            </Template>
                        </Font>
                    </Text>
                </PartText>
            </Complication>
        </ComplicationSlot>
        <!-- Top-right -->
        <PartDraw x="345" y="105" width="64" height="64">
            <Ellipse x="0" y="0" width="64" height="64">
                <Fill color="#ffffffff" />
            </Ellipse>
        </PartDraw>
        <!-- Top -->
        <PartDraw x="193" y="17" width="64" height="64">
            <Ellipse x="0" y="0" width="64" height="64">
                <Fill color="#ffffffff" />
            </Ellipse>
        </PartDraw>
        <!-- Top-left -->
        <PartDraw x="41" y="105" width="64" height="64">
            <Ellipse x="0" y="0" width="64" height="64">
                <Fill color="#ffffffff" />
            </Ellipse>
        </PartDraw>
        <!-- Bottom-left -->
        <ComplicationSlot x="41" y="281" width="64" height="64" slotId="6" supportedTypes="RANGED_VALUE SHORT_TEXT EMPTY">
            <BoundingOval x="0" y="0" width="64" height="64" />
            <DefaultProviderPolicy
                defaultSystemProvider="WATCH_BATTERY"
                defaultSystemProviderType="RANGED_VALUE" />
            <Complication type="RANGED_VALUE">
                <PartDraw x="0" y="0" width="64" height="64">
                    <Arc centerX="32" centerY="32" width="64" height="64" startAngle="195" endAngle="165">
                        <Stroke color="#ffffffff" thickness="8" />
                        <Transform target="endAngle" value="195 + ([BATTERY_PERCENT] / 100 * 330) % 360" />
                    </Arc>
                </PartDraw>
                <PartImage x="22" y="44" width="20" height="20">
                    <Image resource="[COMPLICATION.MONOCHROMATIC_IMAGE]" />
                </PartImage>
                <PartText x="0" y="0" width="64" height="64">
                    <Text>
                        <Font family="SYNC_TO_DEVICE" size="16" color="#ffffffff" weight="BOLD" letterSpacing="0.1">
                            <Template>
                                <![CDATA[%s]]>
                                <Parameter expression="[BATTERY_PERCENT]" />
                            </Template>%
                        </Font>
                    </Text>
                </PartText>
            </Complication>
        </ComplicationSlot>
    </Scene>
</WatchFace>